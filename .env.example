APP_ENV=production
LOG_LEVEL=info

# In Coolify, mount the catalog database into this path.
# The database is not committed to Git because the current catalog file is >100 MB.
CATALOG_DB_PATH=/app/catalog/ebm_kbv.sqlite
STORAGE_DIR=/app/storage
ADMIN_TOKEN=

# Optional: enable Mistral OCR. If disabled or unavailable, the MVP uses embedded PDF text.
ENABLE_MISTRAL_OCR=false
MISTRAL_API_KEY=
MISTRAL_OCR_MODEL=mistral-ocr-latest

# Semantic billing uses Mistral Chat to derive GOPs from evidence and catalog candidates.
# Without MISTRAL_API_KEY the backend falls back to deterministic rules.
ENABLE_SEMANTIC_BILLING=true
MISTRAL_LLM_MODEL=mistral-large-latest

# Only used with docker-compose.local.yml for local development.
FRONTEND_PORT=8080
